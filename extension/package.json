{
    "name":  "akriti-extension",
    "version":  "1.0.0",
    "private":  true,
    "description":  "AI visual review Chrome extension for the Akriti platform.",
    "type":  "module",
    "scripts":  {
                    "dev":  "npx vite build --watch --mode development",
                    "build":  "npx tsc --noEmit \u0026\u0026 npx vite build",
                    "typecheck":  "npx tsc --noEmit",
                    "lint":  "npx eslint .",
                    "format":  "npx prettier --write ."
                },
    "dependencies":  {
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1"
                     },
    "devDependencies":  {
                            "@crxjs/vite-plugin":  "^2.0.0-beta.25",
                            "@eslint/js":  "^8.57.0",
                            "@types/chrome":  "^0.0.268",
                            "@types/react":  "^18.3.3",
                            "@types/react-dom":  "^18.3.0",
                            "@typescript-eslint/eslint-plugin":  "^7.16.1",
                            "@typescript-eslint/parser":  "^7.16.1",
                            "@vitejs/plugin-react":  "^4.3.1",
                            "autoprefixer":  "^10.4.19",
                            "eslint":  "^8.57.0",
                            "eslint-config-prettier":  "^9.1.0",
                            "postcss":  "^8.4.39",
                            "prettier":  "^3.3.3",
                            "tailwindcss":  "^3.4.6",
                            "typescript":  "^5.5.3",
                            "vite":  "^5.3.4"
                        }
}
